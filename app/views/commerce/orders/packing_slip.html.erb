<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <title>装箱单 <%= order.order_number %></title>
  <style>
    body { font-family: sans-serif; max-width: 640px; margin: 2rem auto; padding: 0 1rem; color: #111; }
    h1 { font-size: 1.25rem; }
    table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
    th, td { border: 1px solid #ddd; padding: 0.5rem; text-align: left; font-size: 0.875rem; }
    @media print { body { margin: 0; } .no-print { display: none; } }
  </style>
</head>
<body>
  <h1>装箱单 / Packing Slip</h1>
  <p>订单号：<strong><%= order.order_number %></strong></p>
  <p>日期：<%= l(order.created_at, format: :long) %></p>
  <% if order.shipping_address.present? && order.shipping_address.values.any?(&:present?) %>
    <p><strong>收货人：</strong><%= format_shipping_address(order.shipping_address) %></p>
  <% end %>
  <% if order.shipping_method.present? %>
    <p><strong>配送方式：</strong><%= Commerce::ShippingMethods.label_for(order.shipping_method) %></p>
  <% end %>
  <% if order.notes.present? %>
    <p><strong>备注：</strong><%= order.notes %></p>
  <% end %>

  <table>
    <thead>
      <tr>
        <th>SKU / 商品</th>
        <th>数量</th>
      </tr>
    </thead>
    <tbody>
      <% order.items.each do |item| %>
        <tr>
          <td>
            <%= item.product_name %>
            <% if item.variant_name.present? %> — <%= item.variant_name %><% end %>
          </td>
          <td><%= item.quantity %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <p class="no-print"><button onclick="window.print()">打印</button></p>
  <p><small>McWeb 商城 — 仓库装箱单</small></p>
</body>
</html>
