<% content_for :title, "Setup — #{@step.humanize}" %>

<%= render Ui::PageHeaderComponent.new(
  title: "McWeb 安装向导",
  subtitle: "步骤 #{Setup::WizardController::STEPS.index(@step) + 1} / #{Setup::WizardController::STEPS.size}"
) %>

<hr class="mc-divider">

<% case @step %>
<% when "database" %>
  <%= form_with url: setup_step_path("database"), method: :patch, scope: :setup, class: "space-y-4" do |f| %>
    <p class="mc-form-hint">数据库与密钥将写入 <code>config/local.yml</code>，无需配置环境变量。</p>
    <div>
      <label class="mc-form-label" for="setup_host">数据库主机</label>
      <%= f.text_field :host, value: @settings.dig("database", "host") || "127.0.0.1", class: "mc-input w-full", required: true, id: "setup_host" %>
    </div>
    <div>
      <label class="mc-form-label" for="setup_port">端口</label>
      <%= f.number_field :port, value: @settings.dig("database", "port") || 5432, class: "mc-input w-full", required: true, min: 1, max: 65535, id: "setup_port" %>
    </div>
    <div>
      <label class="mc-form-label" for="setup_username">用户名</label>
      <%= f.text_field :username, value: @settings.dig("database", "username") || "postgres", class: "mc-input w-full", required: true, id: "setup_username" %>
    </div>
    <div>
      <label class="mc-form-label" for="setup_password">密码</label>
      <%= f.password_field :password, autocomplete: "new-password", class: "mc-input w-full", required: true, id: "setup_password" %>
    </div>
    <div>
      <label class="mc-form-label" for="setup_development_database">开发库名称</label>
      <%= f.text_field :development_database, value: @settings.dig("database", "development_database") || "mcweb_development", class: "mc-input w-full", required: true, id: "setup_development_database" %>
    </div>
    <%= f.submit "测试连接并继续", class: "mc-btn mc-btn-primary" %>
  <% end %>

<% when "site" %>
  <%= form_with url: setup_step_path("site"), method: :patch, scope: :setup, class: "space-y-4" do |f| %>
    <div>
      <label class="mc-form-label" for="setup_name">站点名称</label>
      <%= f.text_field :name, value: @settings.dig("site", "name"), class: "mc-input w-full", required: true, id: "setup_name" %>
    </div>
    <div>
      <label class="mc-form-label" for="setup_url">站点 URL</label>
      <%= f.url_field :url, value: @settings.dig("site", "url"), class: "mc-input w-full", placeholder: "http://127.0.0.1:3000", required: true, id: "setup_url" %>
    </div>
    <div class="flex gap-2">
      <% if Mcweb::LocalConfig.complete? %>
        <%= link_to "上一步", setup_step_path("database"), class: "mc-btn no-underline" %>
      <% end %>
      <%= f.submit "继续", class: "mc-btn mc-btn-primary" %>
    </div>
  <% end %>

<% when "admin" %>
  <%= form_with url: setup_step_path("admin"), method: :patch, scope: :setup, class: "space-y-4" do |f| %>
    <div>
      <label class="mc-form-label" for="setup_email">管理员邮箱</label>
      <%= f.email_field :email, value: @settings.dig("admin", "email"), class: "mc-input w-full", required: true, id: "setup_email" %>
    </div>
    <div>
      <label class="mc-form-label" for="setup_username">用户名</label>
      <%= f.text_field :username, value: @settings.dig("admin", "username"), class: "mc-input w-full", required: true, id: "setup_username" %>
    </div>
    <div>
      <label class="mc-form-label" for="setup_display_name">显示名称</label>
      <%= f.text_field :display_name, value: @settings.dig("admin", "display_name"), class: "mc-input w-full", id: "setup_display_name" %>
    </div>
    <div>
      <label class="mc-form-label" for="setup_password">密码</label>
      <%= f.password_field :password, autocomplete: "new-password", class: "mc-input w-full", required: true, minlength: 6, id: "setup_password" %>
      <p class="mc-form-hint">至少 6 个字符，请牢记此密码用于登录。</p>
    </div>
    <div>
      <label class="mc-form-label" for="setup_password_confirmation">确认密码</label>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "mc-input w-full", required: true, minlength: 6, id: "setup_password_confirmation" %>
    </div>
    <div class="flex gap-2">
      <%= link_to "上一步", setup_step_path("site"), class: "mc-btn no-underline" %>
      <%= f.submit "完成安装", class: "mc-btn mc-btn-primary" %>
    </div>
  <% end %>
<% end %>
