<h2>订单通知</h2>
<p>您好 <%= @order.user.username %>，</p>
<p>订单号：<strong><%= @order.order_number %></strong></p>
<p>状态：<strong><%= @order.status %></strong></p>
<% if @pay_url.present? %>
  <p>请在 <strong><%= @expires_label %></strong> 前完成支付，逾期订单将自动取消。</p>
<% end %>
<%= render partial: "commerce/order_mailer/order_details", locals: { order: @order } %>
<% if @pay_url.present? %>
  <p><a href="<%= @pay_url %>">立即支付</a></p>
<% end %>
<p>感谢使用 Mcweb 商城。</p>
