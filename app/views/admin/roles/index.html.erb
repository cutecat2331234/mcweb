<% content_for :title, "Roles" %>

<%= render Ui::PageHeaderComponent.new(title: "Roles & permissions") %>

<table class="mc-table">
  <thead>
    <tr><th>Role</th><th>Key</th><th>Permissions</th><th></th></tr>
  </thead>
  <tbody>
    <% @roles.each do |role| %>
      <tr>
        <td><%= role.name %></td>
        <td><%= role.key %></td>
        <td class="text-sm" style="color: var(--mc-fg-muted)"><%= role.permissions.count %></td>
        <td><%= link_to "View", admin_role_path(role.key), class: "mc-btn text-xs no-underline" %></td>
      </tr>
    <% end %>
  </tbody>
</table>
