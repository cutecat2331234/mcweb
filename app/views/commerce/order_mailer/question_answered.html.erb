<p><%= t("mcweb.mail.greeting", username: @user.username) %></p>
<p><%= t("mcweb.mail.commerce.question_answered.body", product: @product.name) %></p>
<blockquote><%= simple_format(@answer.body) %></blockquote>
<p><strong><%= t("mcweb.mail.commerce.reply_label") %></strong></p>
<p>— <%= @answer.user.username %><% if @answer.official %><%= t("mcweb.mail.commerce.official") %><% end %></p>
<p><a href="<%= store_product_url(@product) %>"><%= t("mcweb.mail.commerce.view_product_detail") %></a></p>
