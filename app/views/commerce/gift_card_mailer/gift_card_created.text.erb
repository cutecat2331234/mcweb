<%= t("mcweb.mail.commerce.gift_card.created_title") %>

<%= t("mcweb.mail.commerce.gift_card.code", code: @card.code) %>
<%= t("mcweb.mail.commerce.gift_card.balance", amount: @card.balance_cents / 100.0, currency: @card.currency) %>
<% if @card.expires_at %><%= t("mcweb.mail.commerce.gift_card.expires_long", time: l(@card.expires_at, format: :long)) %><% end %>

<%= t("mcweb.mail.commerce.gift_card.keep_safe") %>
