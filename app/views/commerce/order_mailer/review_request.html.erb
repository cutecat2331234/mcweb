<h2><%= t("mcweb.mail.commerce.review_request.heading") %></h2>
<p><%= t("mcweb.mail.greeting", username: @user.username) %></p>
<p><%= t("mcweb.mail.commerce.review_request.intro", number: @order.order_number) %></p>
<ul>
  <% @order.items.each do |item| %>
    <li><%= item.product_name %><% if item.variant_name.present? %> — <%= item.variant_name %><% end %></li>
  <% end %>
</ul>
<p><a href="<%= @url %>"><%= t("mcweb.mail.commerce.review_request.action") %></a></p>
