<%= t("mcweb.mail.commerce.webhook_failure.body") %>

<% if @forum_alert -%>
<%= t("mcweb.mail.commerce.webhook_failure.forum", failed: @forum_failed, threshold: @forum_threshold, total: @stats.dig(:forum, :total)) %>
<% end -%>
<% if @store_alert -%>
<%= t("mcweb.mail.commerce.webhook_failure.store", failed: @store_failed, threshold: @store_threshold, total: @stats.dig(:store, :total)) %>
<% end -%>

<%= t("mcweb.mail.commerce.webhook_failure.view_forum") %>: <%= @forum_url %>
<%= t("mcweb.mail.commerce.webhook_failure.view_store") %>: <%= @store_url %>
