<p><%= t("mcweb.mail.greeting", username: @user.username) %></p>
<p><%= t("mcweb.mail.forum.private_message.body", sender: @message.user.username) %></p>
<blockquote><%= simple_format(@message.body.truncate(500)) %></blockquote>
<p><a href="<%= @url %>"><%= t("mcweb.mail.forum.private_message.view_message") %></a></p>
<%= render "notification_unsubscribe" %>
