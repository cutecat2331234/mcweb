<%= t("mcweb.mail.greeting_formal", username: @user.username) %>

<%= t("mcweb.mail.commerce.gift_card.purchased_intro", number: @order.order_number) %>

<% @cards.each do |card| %>
- <%= t("mcweb.mail.commerce.gift_card.code", code: card.code) %>
  <%= t("mcweb.mail.commerce.gift_card.face_value", amount: number_to_currency(card.initial_balance_cents / 100.0, unit: "¥")) %>
  <% if card.expires_at %><%= t("mcweb.mail.commerce.gift_card.expires", time: l(card.expires_at, format: :short)) %><% end %>
<% end %>

<%= t("mcweb.mail.commerce.gift_card.usage") %>
