<table style="width:100%;border-collapse:collapse;margin:1rem 0;">
  <thead>
    <tr>
      <th style="border:1px solid #ddd;padding:0.5rem;text-align:left;"><%= t("mcweb.mail.commerce.product_col") %></th>
      <th style="border:1px solid #ddd;padding:0.5rem;text-align:left;"><%= t("mcweb.mail.commerce.qty_col") %></th>
      <th style="border:1px solid #ddd;padding:0.5rem;text-align:left;"><%= t("mcweb.mail.commerce.line_total_col") %></th>
    </tr>
  </thead>
  <tbody>
    <% order.items.each do |item| %>
      <tr>
        <td style="border:1px solid #ddd;padding:0.5rem;">
          <%= item.product_name %>
          <% if item.variant_name.present? %> — <%= item.variant_name %><% end %>
        </td>
        <td style="border:1px solid #ddd;padding:0.5rem;"><%= item.quantity %></td>
        <td style="border:1px solid #ddd;padding:0.5rem;"><%= number_to_currency(item.total_cents / 100.0, unit: order.currency == "CNY" ? "¥" : "$") %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if order.shipping_address.present? && order.shipping_address.values.any?(&:present?) %>
  <p><%= t("mcweb.mail.commerce.shipping_address_label", address: format_shipping_address(order.shipping_address)) %></p>
<% end %>

<% if order.shipping_method.present? %>
  <p><%= t("mcweb.mail.commerce.shipping_method_label", method: Commerce::ShippingMethods.label_for(order.shipping_method)) %></p>
  <% estimate = Commerce::ShippingMethods.delivery_estimate_label(Commerce::ShippingMethods.find(order.shipping_method)) %>
  <% if estimate.present? %>
    <p><%= t("mcweb.mail.commerce.delivery_estimate_label", estimate: estimate) %></p>
  <% end %>
<% end %>

<% currency_unit = order.currency == "CNY" ? "¥" : "$" %>
<% if order.discount_cents.positive? %>
  <p><%= t("mcweb.mail.commerce.discount_line", code: order.coupon ? " (#{order.coupon.code})" : "", amount: number_to_currency(order.discount_cents / 100.0, unit: currency_unit)) %></p>
<% end %>
<% if order.gift_card_amount_cents.positive? %>
  <p><%= t("mcweb.mail.commerce.gift_card_line", code: order.gift_card ? " (#{order.gift_card.code})" : "", amount: number_to_currency(order.gift_card_amount_cents / 100.0, unit: currency_unit)) %></p>
<% end %>
<p><%= t("mcweb.mail.commerce.subtotal_line", amount: number_to_currency(order.subtotal_cents / 100.0, unit: currency_unit)) %></p>
<% if order.shipping_cents.positive? %>
  <p><%= t("mcweb.mail.commerce.shipping_line", amount: number_to_currency(order.shipping_cents / 100.0, unit: currency_unit)) %></p>
<% elsif order.shipping_cents.zero? && order.subtotal_cents.positive? %>
  <p><%= t("mcweb.mail.commerce.shipping_line", amount: t("mcweb.mail.commerce.free_shipping")) %></p>
<% end %>
<p><strong><%= t("mcweb.mail.commerce.total_line", amount: number_to_currency(order.total_cents / 100.0, unit: currency_unit)) %></strong></p>
