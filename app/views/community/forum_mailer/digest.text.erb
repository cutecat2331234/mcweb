<%= t("mcweb.mail.greeting_formal", username: @user.username) %>

<%= t("mcweb.mail.forum.digest.intro", count: @notifications.count) %>

<% @digest_sections.each do |section| %>
## <%= section[:label] %> (<%= section[:notifications].size %>)
<% section[:notifications].each do |notification| %>
<% url = notification_url_for(notification) %>
- <%= notification.title %> (<%= l(notification.created_at, format: :short) %>)<% if url.present? %> — <%= url %><% end %>
  <% if notification.body.present? %><%= notification.body.truncate(100) %><% end %>
<% end %>

<% end %>
<%= t("mcweb.mail.forum.digest.visit_forum") %>: <%= root_url %>forum/latest

<%= t("mcweb.mail.forum.digest.unsubscribe_digest") %>: <%= @unsubscribe_url %>
<%= t("mcweb.mail.manage_preferences") %>: <%= @preferences_url %>
