#!/usr/bin/env bash
set -euo pipefail

APP_NAME="mcweb"
APP_USER="mcweb"
APP_ROOT="/opt/mcweb"
CONFIG_DIR="/etc/mcweb"
DATA_DIR="/var/lib/mcweb"
LOG_DIR="/var/log/mcweb"
BACKUP_DIR="/var/backups/mcweb"
RUBY_VERSION="3.4.9"

usage() {
  cat <<EOF
McWeb 安装程序

用法:
  bin/install                 交互式安装
  bin/install --unattended    无人值守安装（读取 /etc/mcweb/install.env）

环境变量配置文件示例见 config/templates/install.env.example
EOF
}

require_root() {
  if [[ "${EUID}" -ne 0 ]]; then
    echo "请使用 root 或 sudo 运行安装程序" >&2
    exit 1
  fi
}

detect_os() {
  if [[ -f /etc/os-release ]]; then
    # shellcheck disable=SC1091
    source /etc/os-release
    echo "${ID}"
  else
    echo "unknown"
  fi
}

install_dependencies() {
  local os
  os="$(detect_os)"
  case "$os" in
    ubuntu|debian)
      apt-get update -qq
      DEBIAN_FRONTEND=noninteractive apt-get install -y \
        build-essential libpq-dev libyaml-dev libssl-dev zlib1g-dev \
        libvips-dev imagemagick curl git postgresql postgresql-contrib \
        caddy nodejs
      ;;
    *)
      echo "不支持的操作系统: $os" >&2
      exit 1
      ;;
  esac
}

install_ruby() {
  if ! id -u "${APP_USER}" >/dev/null 2>&1; then
    useradd --system --create-home --home-dir "/home/${APP_USER}" --shell /bin/bash "${APP_USER}"
  fi

  sudo -u "${APP_USER}" bash -lc "
    if ! command -v rbenv >/dev/null; then
      git clone https://github.com/rbenv/rbenv.git ~/.rbenv
      git clone https://github.com/rbenv/ruby-build.git ~/.rbenv/plugins/ruby-build
    fi
    export PATH=\"\$HOME/.rbenv/bin:\$HOME/.rbenv/shims:\$PATH\"
    eval \"\$(rbenv init - bash)\"
    rbenv install -s ${RUBY_VERSION}
    rbenv global ${RUBY_VERSION}
    gem install bundler --no-document
  "
}

deploy_release() {
  local version
  version="$(date +%Y%m%d%H%M%S)"
  local release_dir="${APP_ROOT}/releases/${version}"
  mkdir -p "${release_dir}" "${CONFIG_DIR}" "${DATA_DIR}/uploads" "${DATA_DIR}/templates" "${LOG_DIR}" "${BACKUP_DIR}"
  rsync -a --exclude='.git' --exclude='tmp' --exclude='log' --exclude='node_modules' --exclude='storage' --exclude='vendor/bundle' "$(pwd)/" "${release_dir}/"
  ln -sfn "${release_dir}" "${APP_ROOT}/current"
  chown -R "${APP_USER}:${APP_USER}" "${APP_ROOT}" "${DATA_DIR}" "${LOG_DIR}"
}

configure_app() {
  local env_file="${CONFIG_DIR}/mcweb.env"
  if [[ ! -f "${env_file}" ]]; then
    install -m 600 config/templates/mcweb.env.example "${env_file}"
    echo "请编辑 ${env_file} 后重新运行 bin/setup"
  fi
  grep -q '^RAILS_SERVE_STATIC_FILES=' "${env_file}" || echo 'RAILS_SERVE_STATIC_FILES=1' >> "${env_file}"
  grep -q '^BUNDLE_WITHOUT=' "${env_file}" || echo 'BUNDLE_WITHOUT=development:test' >> "${env_file}"
  grep -q '^BUNDLE_DEPLOYMENT=' "${env_file}" || echo 'BUNDLE_DEPLOYMENT=true' >> "${env_file}"
}

write_systemd_units() {
  install -m 644 config/templates/mcweb-web.service /etc/systemd/system/mcweb-web.service
  install -m 644 config/templates/mcweb-worker.service /etc/systemd/system/mcweb-worker.service
  systemctl daemon-reload
}

write_caddyfile() {
  install -d -m 755 /etc/caddy
  if [[ ! -f /etc/caddy/Caddyfile ]]; then
    install -m 644 config/templates/Caddyfile /etc/caddy/Caddyfile
  fi
}

main() {
  require_root

  local unattended=0
  for arg in "$@"; do
    case "$arg" in
      --unattended) unattended=1 ;;
      -h|--help) usage; exit 0 ;;
    esac
  done

  if [[ "${unattended}" -eq 1 ]]; then
    local install_env="/etc/mcweb/install.env"
    if [[ ! -f "${install_env}" ]]; then
      echo "缺少 ${install_env}，请先复制 config/templates/install.env.example" >&2
      exit 1
    fi
    # shellcheck disable=SC1090
    source "${install_env}"
  fi

  install_dependencies
  install_ruby
  deploy_release
  configure_app
  write_systemd_units
  write_caddyfile

  sudo -u "${APP_USER}" bash -lc "
    export PATH=\"\$HOME/.rbenv/bin:\$HOME/.rbenv/shims:\$PATH\"
    eval \"\$(rbenv init - bash)\"
    cd ${APP_ROOT}/current
    npm ci
    bin/setup
  "

  echo "安装完成。请访问 https://\${MCWEB_DOMAIN:-your-domain}/setup 完成初始化。"
  echo "服务启动: systemctl enable --now mcweb-web mcweb-worker caddy"
}

main "$@"
