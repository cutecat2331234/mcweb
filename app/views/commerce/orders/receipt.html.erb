<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <meta charset="utf-8">
  <title><%= t("mcweb.mail.commerce.receipt.page_title", number: order.order_number) %></title>
  <style>
    body { font-family: sans-serif; max-width: 640px; margin: 2rem auto; padding: 0 1rem; color: #111; }
    h1 { font-size: 1.25rem; }
    table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
    th, td { border: 1px solid #ddd; padding: 0.5rem; text-align: left; font-size: 0.875rem; }
    .total { font-weight: bold; text-align: right; margin-top: 1rem; }
    @media print { body { margin: 0; } }
  </style>
</head>
<body>
  <h1><%= t("mcweb.mail.commerce.receipt.title") %></h1>
  <p><%= t("mcweb.mail.commerce.order_number", number: order.order_number) %></p>
  <p><%= t("mcweb.mail.commerce.receipt.date", date: l(order.created_at, format: :long)) %></p>
  <p><%= t("mcweb.mail.commerce.order_status", status: I18n.t("mcweb.labels.order_status.#{order.status}", default: order.status)) %></p>
  <% if order.notes.present? %>
    <p><%= t("mcweb.mail.commerce.receipt.notes", notes: order.notes) %></p>
  <% end %>
  <% if order.shipping_address.present? && order.shipping_address.values.any?(&:present?) %>
    <p><%= t("mcweb.mail.commerce.shipping_address_label", address: format_shipping_address(order.shipping_address)) %></p>
  <% end %>

  <table>
    <thead>
      <tr>
        <th><%= t("mcweb.mail.commerce.product_col") %></th>
        <th><%= t("mcweb.mail.commerce.qty_col") %></th>
        <th><%= t("mcweb.mail.commerce.line_total_col") %></th>
      </tr>
    </thead>
    <tbody>
      <% order.items.each do |item| %>
        <tr>
          <td>
            <%= item.product_name %>
            <% if item.variant_name.present? %> — <%= item.variant_name %><% end %>
          </td>
          <td><%= item.quantity %></td>
          <td><%= number_to_currency(item.total_cents / 100.0, unit: order.currency == "CNY" ? "¥" : "$") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <% currency_unit = order.currency == "CNY" ? "¥" : "$" %>
  <% if order.discount_cents.positive? %>
    <p class="total"><%= t("mcweb.mail.commerce.discount_line", code: order.coupon ? " (#{order.coupon.code})" : "", amount: number_to_currency(order.discount_cents / 100.0, unit: currency_unit)) %></p>
  <% end %>
  <% if order.gift_card_amount_cents.positive? %>
    <p class="total"><%= t("mcweb.mail.commerce.gift_card_line", code: order.gift_card ? " (#{order.gift_card.code})" : "", amount: number_to_currency(order.gift_card_amount_cents / 100.0, unit: currency_unit)) %></p>
  <% end %>
  <p class="total"><%= t("mcweb.mail.commerce.subtotal_line", amount: number_to_currency(order.subtotal_cents / 100.0, unit: currency_unit)) %></p>
  <% if order.shipping_cents.positive? %>
    <p class="total"><%= t("mcweb.mail.commerce.shipping_line", amount: number_to_currency(order.shipping_cents / 100.0, unit: currency_unit)) %></p>
  <% elsif order.shipping_cents.zero? && order.subtotal_cents.positive? %>
    <p class="total"><%= t("mcweb.mail.commerce.shipping_line", amount: t("mcweb.mail.commerce.free_shipping")) %></p>
  <% end %>
  <p class="total"><%= t("mcweb.mail.commerce.total_line", amount: number_to_currency(order.total_cents / 100.0, unit: currency_unit)) %></p>

  <p><small><%= t("mcweb.mail.commerce.receipt.footer") %></small></p>
</body>
</html>
