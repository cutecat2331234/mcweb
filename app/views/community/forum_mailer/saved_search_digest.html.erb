<p><%= t("mcweb.mail.greeting", username: @user.username) %></p>

<p><%= t("mcweb.mail.forum.saved_search_digest.intro", name: @search.name, count: @topics.size) %></p>

<% if @filter_labels.present? %>
  <p style="font-size:13px;color:#444;margin:12px 0;">
    <%= t("mcweb.mail.forum.saved_search_digest.filters") %>
    <% @filter_labels.each do |label| %>
      <span style="display:inline-block;background:#f0f0f0;border-radius:4px;padding:2px 8px;margin:2px 4px 2px 0;"><%= label %></span>
    <% end %>
  </p>
<% end %>

<ul>
  <% @topics.each do |topic| %>
    <li><a href="<%= root_url.chomp('/') %><%= forum_topic_path(topic) %>"><%= topic.title %></a></li>
  <% end %>
</ul>

<p>
  <a href="<%= @url %>"><%= t("mcweb.mail.forum.saved_search_digest.view_results") %></a>
  ·
  <a href="<%= @rss_url %>"><%= t("mcweb.mail.forum.saved_search_digest.rss") %></a>
</p>

<p style="font-size:12px;color:#666;margin-top:24px;">
  <%= t("mcweb.mail.forum.saved_search_digest.daily_reminder") %>
  <a href="<%= @unsubscribe_url %>"><%= t("mcweb.mail.forum.saved_search_digest.unsubscribe_search") %></a>
  ·
  <a href="<%= @preferences_url %>"><%= t("mcweb.mail.forum.saved_search_digest.manage_saved") %></a>
</p>
