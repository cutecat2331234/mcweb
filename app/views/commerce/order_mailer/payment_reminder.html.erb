<h2><%= t("mcweb.mail.commerce.payment_reminder.heading") %></h2>
<p><%= t("mcweb.mail.greeting_formal", username: @order.user.username) %></p>
<p><%= t("mcweb.mail.commerce.payment_reminder.body", number: @order.order_number) %></p>
<% if @expires_label.present? %>
  <p><%= t("mcweb.mail.commerce.pay_before", expires: @expires_label) %></p>
<% end %>
<%= render partial: "commerce/order_mailer/order_details", locals: { order: @order } %>
<% if @pay_url.present? %>
  <p><a href="<%= @pay_url %>"><%= t("mcweb.mail.commerce.pay_now") %></a></p>
<% end %>
<p><%= t("mcweb.mail.commerce.thanks") %></p>
