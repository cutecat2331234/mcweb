<p>你好 <%= @user.username %>，</p>

<p>以下是您订阅的论坛摘要（<%= @notifications.count %> 条）：</p>

<% @digest_sections.each do |section| %>
  <h3 style="font-size:14px;margin:16px 0 8px;color:#333;">
    <%= section[:label] %> (<%= section[:notifications].size %>)
    <span style="font-size:12px;font-weight:normal;">
      · <a href="<%= notification_type_unsubscribe_url_for(@user, section[:type]) %>" style="color:#666;">关闭此类邮件</a>
    </span>
  </h3>
  <ul>
    <% section[:notifications].each do |notification| %>
      <% url = notification_url_for(notification) %>
      <li style="margin-bottom:8px;">
        <% if url.present? %>
          <a href="<%= url %>" style="font-weight:600;color:#2563eb;text-decoration:none;"><%= notification.title %></a>
        <% else %>
          <strong><%= notification.title %></strong>
        <% end %>
        <span style="color:#666;font-size:12px;">(<%= l(notification.created_at, format: :short) %>)</span>
        <% if notification.body.present? %>
          <br><span style="color:#444;"><%= notification.body.truncate(100) %></span>
        <% end %>
      </li>
    <% end %>
  </ul>
<% end %>

<p>
  <a href="<%= @unread_notifications_url %>">查看全部未读通知</a>
  ·
  <a href="<%= root_url.chomp('/') %><%= forum_latest_path %>">访问论坛</a>
</p>

<p style="font-size:12px;color:#666;margin-top:24px;">
  <a href="<%= @unsubscribe_url %>">一键关闭论坛邮件摘要</a>
  ·
  <a href="<%= @mention_unsubscribe_url %>">关闭 @提及 邮件</a>
  ·
  <a href="<%= @preferences_url %>">在通知偏好中管理</a>
</p>
