<p><%= t("mcweb.mail.greeting", username: @user.username) %></p>

<p><%= t("mcweb.mail.forum.digest.intro", count: @notifications.count) %></p>

<% @digest_sections.each do |section| %>
  <h3 style="font-size:14px;margin:16px 0 8px;color:#333;">
    <%= section[:label] %> (<%= section[:notifications].size %>)
    <span style="font-size:12px;font-weight:normal;">
      · <a href="<%= notification_type_unsubscribe_url_for(@user, section[:type]) %>" style="color:#666;"><%= t("mcweb.mail.forum.digest.disable_type") %></a>
    </span>
  </h3>
  <ul>
    <% section[:notifications].each do |notification| %>
      <% url = notification_url_for(notification) %>
      <li style="margin-bottom:8px;">
        <% if url.present? %>
          <a href="<%= url %>" style="font-weight:600;color:#2563eb;text-decoration:none;"><%= notification.title %></a>
        <% else %>
          <strong><%= notification.title %></strong>
        <% end %>
        <span style="color:#666;font-size:12px;">(<%= l(notification.created_at, format: :short) %>)</span>
        <% if notification.body.present? %>
          <br><span style="color:#444;"><%= notification.body.truncate(100) %></span>
        <% end %>
      </li>
    <% end %>
  </ul>
<% end %>

<p>
  <a href="<%= @unread_notifications_url %>"><%= t("mcweb.mail.forum.digest.view_unread") %></a>
  ·
  <a href="<%= root_url.chomp('/') %><%= forum_latest_path %>"><%= t("mcweb.mail.forum.digest.visit_forum") %></a>
</p>

<p style="font-size:12px;color:#666;margin-top:24px;">
  <a href="<%= @unsubscribe_url %>"><%= t("mcweb.mail.forum.digest.unsubscribe_digest") %></a>
  ·
  <a href="<%= @mention_unsubscribe_url %>"><%= t("mcweb.mail.forum.digest.unsubscribe_mentions") %></a>
  ·
  <a href="<%= @preferences_url %>"><%= t("mcweb.mail.manage_preferences") %></a>
</p>
