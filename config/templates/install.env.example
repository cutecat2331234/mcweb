# McWeb unattended install configuration
# Copy to /etc/mcweb/install.env before running: bin/install --unattended

# Required
MCWEB_DOMAIN=example.com
MCWEB_ADMIN_EMAIL=admin@example.com

# PostgreSQL 18 (installed from PGDG apt repo by bin/install)
# Leave host empty for local peer auth
MCWEB_DATABASE_USERNAME=mcweb
MCWEB_DATABASE_PASSWORD=change_me
MCWEB_DATABASE_HOST=
MCWEB_DATABASE_PORT=

# Paths (defaults shown)
MCWEB_APP_ROOT=/opt/mcweb
MCWEB_CONFIG_DIR=/etc/mcweb
MCWEB_DATA_DIR=/var/lib/mcweb
MCWEB_LOG_DIR=/var/log/mcweb
MCWEB_BACKUP_DIR=/var/backups/mcweb

# Optional: skip apt/caddy install when dependencies already present
# MCWEB_SKIP_APT=1
