<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <meta charset="utf-8">
  <title><%= t("mcweb.mail.commerce.packing_slip.page_title", number: order.order_number) %></title>
  <style>
    body { font-family: sans-serif; max-width: 640px; margin: 2rem auto; padding: 0 1rem; color: #111; }
    h1 { font-size: 1.25rem; }
    table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
    th, td { border: 1px solid #ddd; padding: 0.5rem; text-align: left; font-size: 0.875rem; }
    @media print { body { margin: 0; } .no-print { display: none; } }
  </style>
</head>
<body>
  <h1><%= t("mcweb.mail.commerce.packing_slip.title") %></h1>
  <p><%= t("mcweb.mail.commerce.order_number", number: order.order_number) %></p>
  <p><%= t("mcweb.mail.commerce.receipt.date", date: l(order.created_at, format: :long)) %></p>
  <% if order.shipping_address.present? && order.shipping_address.values.any?(&:present?) %>
    <p><strong><%= t("mcweb.mail.commerce.packing_slip.recipient", address: format_shipping_address(order.shipping_address)) %></strong></p>
  <% end %>
  <% if order.shipping_method.present? %>
    <p><strong><%= t("mcweb.mail.commerce.shipping_method_label", method: Commerce::ShippingMethods.label_for(order.shipping_method)) %></strong></p>
  <% end %>
  <% if order.notes.present? %>
    <p><strong><%= t("mcweb.mail.commerce.packing_slip.notes", notes: order.notes) %></strong></p>
  <% end %>

  <table>
    <thead>
      <tr>
        <th><%= t("mcweb.mail.commerce.packing_slip.sku_product") %></th>
        <th><%= t("mcweb.mail.commerce.qty_col") %></th>
      </tr>
    </thead>
    <tbody>
      <% order.items.each do |item| %>
        <tr>
          <td>
            <%= item.product_name %>
            <% if item.variant_name.present? %> — <%= item.variant_name %><% end %>
          </td>
          <td><%= item.quantity %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <p class="no-print"><button onclick="window.print()"><%= t("mcweb.mail.commerce.packing_slip.print") %></button></p>
  <p><small><%= t("mcweb.mail.commerce.packing_slip.footer") %></small></p>
</body>
</html>
