# McWeb production environment
RAILS_ENV=production
RAILS_LOG_TO_STDOUT=1
# 由 Puma 提供 /assets 静态文件（Caddy 仅反向代理时必需）
RAILS_SERVE_STATIC_FILES=1
# 生产环境使用 vendor/bundle 部署（发布包已内置 gems）
BUNDLE_DEPLOYMENT=true
BUNDLE_WITHOUT=development:test
# 公开技术栈指纹，便于 Wappalyzer 等工具识别 Ruby on Rails（设为 0 可关闭）
MCWEB_PUBLIC_TECH_STACK=1
MCWEB_DATABASE_USERNAME=mcweb
MCWEB_DATABASE_PASSWORD=change_me
# 留空则使用 Unix socket（同机 peer 认证）；远程 PostgreSQL 时填写主机名
MCWEB_DATABASE_HOST=
# 非默认端口时填写，例如 5433
MCWEB_DATABASE_PORT=
SECRET_KEY_BASE=generate_with_rails_secret
LOCKBOX_MASTER_KEY=generate_64_hex_chars
MCWEB_HOST=example.com
MCWEB_TEMPLATE_DIR=/var/lib/mcweb/templates
MCWEB_BACKUP_DIR=/var/backups/mcweb
