# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets
/public/sitemap.xml

# Ignore key files for decrypting credentials and more.
/config/*.key

# Local instance configuration (database, secrets) written during setup.
/config/local*.yml
!/config/local.yml.example
/config/image_packs.yml


/app/assets/builds/*
!/app/assets/builds/.keep

# Vite Ruby
/public/vite*
node_modules
# Vite uses dotenv and suggests to ignore local-only env files. See
# https://vitejs.dev/guide/env-and-mode.html#env-files
*.local
!Procfile.local

dist/

# Gradle (MC connector plugin)
plugins/**/build/
plugins/**/.gradle/

# Local deploy script (contains server credentials)
scripts/deploy-direct.py

# Test / build artifacts
test_errors.txt
nodes/**/bin/

# Claude Code local agent state (worktrees, session data)
/.claude/
